rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid (string), email (string), displayName (string), photoURL (string), createdAt (string)
    //
    // Collection: users/{userId}/accounts
    // Fields: userId (string), name (string), balance (number), updatedAt (string)
    //
    // Collection: users/{userId}/investments
    // Fields: userId (string), name (string), category (string), value (number), updatedAt (string)
    //
    // Collection: users/{userId}/liabilities
    // Fields: userId (string), name (string), amount (number), updatedAt (string)
    //
    // Collection: users/{userId}/transactions
    // Fields: userId (string), date (string), amount (number), type (string), accountId (string), notes (string)
    //
    // Collection: users/{userId}/information
    // Fields: userId (string), type (string), provider (string), accountNumber (string), accountName (string), updatedAt (string)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "Anandafa123@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['userId', 'name', 'balance']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.balance is number;
    }

    function isValidInvestment(data) {
      return data.keys().hasAll(['userId', 'name', 'value']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.value is number;
    }

    function isValidLiability(data) {
      return data.keys().hasAll(['userId', 'name', 'amount']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.amount is number;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'date', 'amount', 'type', 'accountId']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['income', 'expense', 'debt_payment', 'debt_expense', 'investment_deposit', 'investment_withdrawal'];
    }

    function isValidInformation(data) {
      return data.keys().hasAll(['userId', 'type', 'provider', 'accountNumber']) &&
             data.userId == request.auth.uid &&
             data.type in ['bank', 'ewallet', 'crypto', 'rdn'] &&
             data.provider is string && data.provider.size() > 0 && data.provider.size() < 100 &&
             data.accountNumber is string && data.accountNumber.size() > 0 && data.accountNumber.size() < 100;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /accounts/{accountId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidAccount(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
      
      match /investments/{investmentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidInvestment(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
      
      match /liabilities/{liabilityId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidLiability(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
      
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidTransaction(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /information/{infoId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidInformation(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
